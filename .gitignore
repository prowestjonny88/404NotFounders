# ============================================================
# LintasNiaga monorepo — .gitignore
# ============================================================

# Node / pnpm — match at ANY depth (no leading slash)
node_modules/
.pnp
.pnp.js
pnpm-debug.log*

# Python virtualenvs — match at ANY depth
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Next.js
.next/
out/

# Test / coverage
coverage/
.pytest_cache/
htmlcov/

# Build artefacts
*.tsbuildinfo
next-env.d.ts

# Env files — NEVER commit secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editor
.vercel
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Broken / temp scaffolding directories
apps/web-broken-*/

# Stitch design export (frontend design only)
stitch_lintasniaga_procurement_copilot/

# Local temp dirs created during verification
.tmp_test/
data/tmp/test_runs/

# Data — snapshots and raw are runtime artefacts, don't commit them
data/snapshots/
data/raw/
data/tmp/

# Uploads directory (runtime)
apps/api/uploads/

# SQLite database (runtime)
*.db
*.db-shm
*.db-wal
